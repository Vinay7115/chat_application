# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT=5001

# ─────────────────────────────────────────────
# MongoDB
# Get your connection string from: https://cloud.mongodb.com
# ─────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0

# ─────────────────────────────────────────────
# JWT
# Use a long, random secret (e.g. generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
# ─────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here

# ─────────────────────────────────────────────
# Cloudinary (for image uploads)
# Get these from: https://console.cloudinary.com → Settings → API Keys
# ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─────────────────────────────────────────────
# Node Environment
# ─────────────────────────────────────────────
NODE_ENV=development
